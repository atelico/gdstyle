[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = false

[libraries]
linux.debug.x86_64 = "res://addons/gdstyle/bin/libgdstyle_gdext.so"
linux.release.x86_64 = "res://addons/gdstyle/bin/libgdstyle_gdext.so"
macos.debug.x86_64 = "res://addons/gdstyle/bin/libgdstyle_gdext.x86_64.dylib"
macos.release.x86_64 = "res://addons/gdstyle/bin/libgdstyle_gdext.x86_64.dylib"
macos.debug.arm64 = "res://addons/gdstyle/bin/libgdstyle_gdext.arm64.dylib"
macos.release.arm64 = "res://addons/gdstyle/bin/libgdstyle_gdext.arm64.dylib"
windows.debug.x86_64 = "res://addons/gdstyle/bin/gdstyle_gdext.dll"
windows.release.x86_64 = "res://addons/gdstyle/bin/gdstyle_gdext.dll"
